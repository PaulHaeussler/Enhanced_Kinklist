# Add these values to your existing SWAG container environment.
# Keep the existing URL value as your primary SWAG domain.

# Use this when Enhanced Kinklist will live on a separate full domain,
# for example https://kinkli.st rather than https://kinklist.example.com.
EXTRA_DOMAINS=kinkli.st,www.kinkli.st

# If you use DNS validation, make sure the DNSPLUGIN and credentials file
# in /config/dns-conf cover the provider for the secondary domain too.
# DNSPLUGIN=cloudflare

# If this is a subdomain of the existing SWAG URL instead of a separate
# full domain, do not use EXTRA_DOMAINS for this. Add the subdomain to
# SUBDOMAINS instead, for example:
# SUBDOMAINS=www,kinklist
