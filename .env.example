# Compose
APP_PORT=5055
SWAG_NETWORK=swag_proxy

# Flask app database connection
DB_SCHEMA=kl
DB_USER=kinklist
DB_PW=change_this_app_password

# MariaDB root account used only for initialization and health checks
MARIADB_ROOT_PASSWORD=change_this_root_password

# Gunicorn
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=60
STATS_INTERVAL=21600

# Direct Flask dev server, only used when running enhanced_kinklist.py directly
DEV_PORT=5055
